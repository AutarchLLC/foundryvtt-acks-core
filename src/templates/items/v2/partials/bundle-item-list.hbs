{{! PARAMS:  }}
{{!   items - array of items }}
{{!   title - string title for the section }}
<section class="item-list-section">

  <div class="list-header">

    <div class="list-header__controls left-side">
      <a class="item-control toggle" data-action="toggleListSection">
        <i class="fas fa-caret-down"></i>
      </a>
    </div>

    <div class="item__name">{{title}}</div>

    <div class="list-header__controls controls__item"></div>

  </div>

  <div class="item-list-wrapper expanded">
    <ul class="item-list unlist">
      {{#each items as |item|}}
        <li class="item" data-item-id="{{item.uuid}}">

          <div class="item-row">

            <div class="item__icon">
              <img src="{{item.img}}" alt="{{item.name}}" class="item__image"/>
            </div>

            <div class="item__name">
              <a data-action="viewItemFromBundle">{{item.name}}</a>
            </div>

            <div class="item__quantity">
              <a data-action="changeQuantityInBundle"># {{item.quantity}}</a>
            </div>

            <div class="list-header__controls controls__item">

              <a class="item-control" data-tooltip='{{localize "ACKS.Delete"}}' data-action="viewItemFromBundle">
                <i class="fas fa-eye"></i>
              </a>

              <a class="item-control" data-tooltip='{{localize "ACKS.Delete"}}' data-action="deleteItemFromBundle">
                <i class="fas fa-trash"></i>
              </a>

            </div>

          </div>

        </li>
      {{/each}}
    </ul>
  </div>

</section>
