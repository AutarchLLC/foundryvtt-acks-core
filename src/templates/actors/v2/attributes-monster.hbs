<section class="tab {{ tab.cssClass }} sheet-attributes" data-group="primary" data-tab="attributes">
  <div class="content flexrow">

    <div class="panel flex-4">

      <section class="item-list-section">

        <div class="list-header">

          <div class="item__name">{{localize "ACKS.category.abilities"}} & {{localize 'ACKS.category.equipment'}}</div>

          {{#if owner}}
            <div class="list-header__controls controls__armor">

              <a class="item-control" data-tooltip='{{localize "ACKS.items.resetAttacks"}}' data-action="resetAttacks">
                <i class="fas fa-sync"></i>
              </a>

              <a class="item-control" data-tooltip='{{localize "ACKS.Add"}}' data-action="itemCreate"
                 data-type="choice" data-choices="weapon,ability,armor,item">
                <i class="fas fa-plus"></i>
              </a>

            </div>
          {{/if}}

        </div>

        <ul class="item-list unlist">

          {{#each abilities as |item|}}
            <li class="item" data-item-id="{{item._id}}">

              <div class="item-row">

                <div class="item__pattern" data-action="changePattern" style="--pattern-color: {{item.system.pattern}};"
                     data-tooltip="{{localize 'ACKS.items.pattern'}}"></div>

                <div class="item__icon {{#if item.system.roll}}item-usable{{/if}}" data-action="itemUse">
                  <img src="{{item.img}}" alt="{{item.name}}" class="item__image"/>
                </div>

                <div class="item__text">
                  <a data-action="toggleSummary">{{item.name}}</a>
                </div>

                {{#if ../owner}}
                  <div class="item__controls">

                    <a class="item-control" data-tooltip='{{localize "ACKS.Show"}}' data-action="itemShow">
                      <i class="fas fa-eye"></i>
                    </a>
                    <a class="item-control" data-tooltip='{{localize "ACKS.Edit"}}' data-action="itemEdit">
                      <i class="fas fa-edit"></i>
                    </a>
                    <a class="item-control" data-tooltip='{{localize "ACKS.Delete"}}' data-action="itemDelete">
                      <i class="fas fa-trash"></i>
                    </a>

                  </div>
                {{/if}}

              </div>

              <div class="item-summary"></div>

            </li>
          {{/each}}

          {{#each owned as |section| }}
            {{#each section as |item|}}
              <li class="item" data-item-id="{{item._id}}">
                <div class="item-row">

                  {{#if (eq item.type 'weapon')}}
                    <div class="item__pattern" data-action="changePattern"
                         style="--pattern-color: {{item.system.pattern}};"
                         data-tooltip="{{localize 'ACKS.items.pattern'}}"></div>
                  {{/if}}

                  <div class="item__icon {{#if (eq item.type 'weapon')}}item-usable{{/if}}" data-action="itemUse">
                    <img src="{{item.img}}" alt="{{item.name}}" class="item__image"/>
                  </div>

                  <div class="item__text">
                    <a data-action="toggleSummary">{{item.name}}</a>
                  </div>

                  {{#if (eq item.type 'weapon')}}
                    <div class="item__attack-count">
                      <input class="item-input small" type="number" data-name="system.counter.value" data-kind="item"
                             value="{{item.system.counter.value}}" data-dtype="Number"
                             data-tooltip="{{localize 'ACKS.items.roundAttacks'}}"/>
                      <span>/</span>
                      <input class="item-input small" type="number" data-name="system.counter.max" data-kind="item"
                             value="{{item.system.counter.max}}" data-dtype="Number"
                             data-tooltip="{{localize 'ACKS.items.roundAttacksMax'}}"/>
                    </div>
                  {{/if}}

                  {{#if ../../owner}}
                    <div class="item__controls">

                      <a class="item-control" data-tooltip='{{localize "ACKS.Edit"}}' data-action="itemEdit">
                        <i class="fas fa-edit"></i>
                      </a>
                      <a class="item-control" data-tooltip='{{localize "ACKS.Delete"}}' data-action="itemDelete">
                        <i class="fas fa-trash"></i>
                      </a>

                    </div>
                  {{/if}}

                </div>

                <div class="item-summary"></div>

              </li>
            {{/each}}
          {{/each}}

        </ul>

      </section>

    </div>

    <div class="panel flexcol">

      <!-- Paralysis -->
      <div class="form-group-h">
        <a class="rollable-header" data-tooltip="{{localize 'ACKS.saves.paralysis.long'}}" data-action="rollSave"
           data-save="paralysis">
          <i class="fa-solid fa-dice-d20 rollable-header__icon"></i>
          <label class="rollable-header__label" for="{{@root.partId}}-paralysis">
            {{ localize "ACKS.saves.paralysis.long" }}
          </label>
        </a>
        <div class="form-fields">
          <input type="text" name="system.saves.paralysis.value" value="{{system.saves.paralysis.value}}"
                 id="{{@root.partId}}-paralysis" data-dtype="Number" placeholder="18"
                 class="form-group-h__narrow-input"/>
        </div>
      </div>
      <!-- Death -->
      <div class="form-group-h">
        <a class="rollable-header" data-tooltip="{{localize 'ACKS.saves.death.long'}}" data-action="rollSave"
           data-save="death">
          <i class="fa-solid fa-dice-d20 rollable-header__icon"></i>
          <label class="rollable-header__label" for="{{@root.partId}}-death">
            {{ localize "ACKS.saves.death.long" }}
          </label>
        </a>
        <div class="form-fields">
          <input type="text" name="system.saves.death.value" value="{{system.saves.death.value}}"
                 id="{{@root.partId}}-death" data-dtype="Number" placeholder="18" class="form-group-h__narrow-input"/>
        </div>
      </div>
      <!-- Breath -->
      <div class="form-group-h">
        <a class="rollable-header" data-tooltip="{{localize 'ACKS.saves.breath.long'}}" data-action="rollSave"
           data-save="breath">
          <i class="fa-solid fa-dice-d20 rollable-header__icon"></i>
          <label class="rollable-header__label" for="{{@root.partId}}-breath">
            {{ localize "ACKS.saves.breath.long" }}
          </label>
        </a>
        <div class="form-fields">
          <input type="text" name="system.saves.breath.value" value="{{system.saves.breath.value}}"
                 id="{{@root.partId}}-breath" data-dtype="Number" placeholder="18" class="form-group-h__narrow-input"/>
        </div>
      </div>
      <!-- Implements -->
      <div class="form-group-h">
        <a class="rollable-header" data-tooltip="{{localize 'ACKS.saves.implements.long'}}" data-action="rollSave"
           data-save="implements">
          <i class="fa-solid fa-dice-d20 rollable-header__icon"></i>
          <label class="rollable-header__label" for="{{@root.partId}}-implements">
            {{ localize "ACKS.saves.implements.long" }}
          </label>
        </a>
        <div class="form-fields">
          <input type="text" name="system.saves.implements.value" value="{{system.saves.implements.value}}"
                 id="{{@root.partId}}-implements" data-dtype="Number" placeholder="18"
                 class="form-group-h__narrow-input"/>
        </div>
      </div>
      <!-- Spell -->
      <div class="form-group-h">
        <a class="rollable-header" data-tooltip="{{localize 'ACKS.saves.spell.long'}}" data-action="rollSave"
           data-save="spell">
          <i class="fa-solid fa-dice-d20 rollable-header__icon"></i>
          <label class="rollable-header__label" for="{{@root.partId}}-spell">
            {{ localize "ACKS.saves.spell.long" }}
          </label>
        </a>
        <div class="form-fields">
          <input type="text" name="system.saves.spell.value" value="{{system.saves.spell.value}}"
                 id="{{@root.partId}}-spell" data-dtype="Number" placeholder="18" class="form-group-h__narrow-input"/>
        </div>
      </div>

    </div>

  </div>
</section>
